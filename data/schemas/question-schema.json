{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cert Study Question",
  "description": "Schema for a single question in the app's flat exam JSON format.",
  "type": "object",
  "required": ["id", "domain", "domainName", "question", "options", "answer"],
  "properties": {
    "id": {
      "description": "Unique integer identifier within the exam file.",
      "type": "integer"
    },
    "domain": {
      "description": "Domain number (matches exam.domains[].number).",
      "type": "integer",
      "minimum": 1
    },
    "domainName": {
      "description": "Human-readable domain name.",
      "type": "string"
    },
    "topic": {
      "description": "Optional sub-topic label shown in the quiz UI.",
      "type": "string"
    },
    "question": {
      "description": "Full question text. Use \\n to separate a scenario preamble from the question stem.",
      "type": "string",
      "minLength": 10
    },
    "options": {
      "description": "Answer choices keyed A–D.",
      "type": "object",
      "required": ["A", "B", "C", "D"],
      "properties": {
        "A": { "type": "string" },
        "B": { "type": "string" },
        "C": { "type": "string" },
        "D": { "type": "string" }
      },
      "additionalProperties": false
    },
    "answer": {
      "description": "Key of the correct option.",
      "type": "string",
      "enum": ["A", "B", "C", "D"]
    },
    "rationale": {
      "description": "Overall explanation shown when optionRationales is absent.",
      "type": "string"
    },
    "optionRationales": {
      "description": "Per-option explanation (shown in the full explanation panel).",
      "type": "object",
      "properties": {
        "A": { "type": "string" },
        "B": { "type": "string" },
        "C": { "type": "string" },
        "D": { "type": "string" }
      },
      "additionalProperties": false
    },
    "references": {
      "description": "Optional list of supporting documentation links rendered under the answer in the UI.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "text": { "type": "string" },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
