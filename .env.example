# .env.example — copy to .env and fill in your values
# Used by CLI scripts in scripts/ only.
# The vanilla app (index.html) uses Ollama locally — no API key needed.

# Anthropic API key (required for scripts/generate-questions.js)
ANTHROPIC_API_KEY=your-api-key-here

# Override the model used by generate-questions.js (optional)
# Default: claude-sonnet-4-6
# Options: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# LLM_MODEL=claude-sonnet-4-6

# ── Accounts & cross-device sync (Supabase) ────────────────────────────
# Used by the browser app for Google sign-in + progress sync.
# In Docker/K8s these are injected into config.js at runtime by
# docker-entrypoint.sh. Leave blank to run in anonymous (localStorage) mode.
# Find both in Supabase -> Project Settings -> API. The anon key is public-safe
# (Row-Level Security protects the data — see supabase/schema.sql).
SUPABASE_URL=
SUPABASE_ANON_KEY=
