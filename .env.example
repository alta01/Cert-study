# .env.example — copy to .env and fill in your values

# Anthropic API key (required for AI question generation)
VITE_ANTHROPIC_API_KEY=your-api-key-here

# LLM model to use (default: claude-3-5-sonnet-20241022)
VITE_LLM_MODEL=claude-3-5-sonnet-20241022

# Override the Anthropic base URL (optional, for proxies or alternative providers)
# VITE_LLM_BASE_URL=https://api.anthropic.com

# Enable the Adaptive Difficulty Agent (default: false)
VITE_ENABLE_ADAPTIVE=false

# Default exam feedback mode: 'immediate' or 'end' (default: end)
VITE_DEFAULT_EXAM_MODE=end
